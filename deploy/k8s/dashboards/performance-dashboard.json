{
  "uid": "live-auction-performance",
  "title": "Live Auction 性能压测观测",
  "tags": ["live-auction", "performance", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-30m", "to": "now"},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "# Live Auction\n## 性能压测观测"
      },
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"x": 0, "y": 0, "w": 5, "h": 4}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "出价 QPS",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval]))",
          "legendFormat": "bid qps",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 30}, {"color": "red", "value": 80}]}}, "overrides": []},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
      "gridPos": {"x": 5, "y": 0, "w": 4, "h": 4}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "出价 P50 / P95 / P99",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.2}, {"color": "red", "value": 1}]}}, "overrides": []},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
      "gridPos": {"x": 9, "y": 0, "w": 7, "h": 4}
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "5xx 比例",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(http_server_request_count_total{http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_count_total[$__rate_interval])), 0.001)", "legendFormat": "5xx", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3, "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}}, "overrides": []},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true},
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WebSocket 当前连接",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(ws_connection_active)", "legendFormat": "active", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background", "graphMode": "area", "justifyMode": "center"},
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "出价接口延迟趋势",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items/[^/]+/bids|/api/v1/items/\\\\{item_id\\\\}/bids\"}[$__rate_interval])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis Lua 耗时与返回码",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(auction_place_bid_lua_duration_bucket[$__rate_interval])) by (le, code))", "legendFormat": "lua p95 code={{code}}", "refId": "A"},
        {"expr": "sum(rate(auction_place_bid_lua_result_count_total[$__rate_interval])) by (code)", "legendFormat": "lua code {{code}}/s", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 3, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "出价结果分布",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(auction_bid_count_total[$__rate_interval])) by (result, reason)", "legendFormat": "{{result}} {{reason}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 12, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 8}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "BidLog / MySQL 写入",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(db_client_operation_count_total{db_sql_table=~\"bid_logs|bid_logs.*\"}[$__rate_interval])) by (db_operation, result)", "legendFormat": "{{db_operation}} {{result}}/s", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_bucket{db_sql_table=~\"bid_logs|bid_logs.*\"}[$__rate_interval])) by (le, db_operation))", "legendFormat": "{{db_operation}} p95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 3, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 8}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "MySQL 连接池",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "db_client_connections_open", "legendFormat": "open", "refId": "A"},
        {"expr": "db_client_connections_in_use", "legendFormat": "in_use", "refId": "B"},
        {"expr": "db_client_connections_idle", "legendFormat": "idle", "refId": "C"},
        {"expr": "rate(db_client_connections_wait_count[$__rate_interval])", "legendFormat": "wait/s", "refId": "D"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 8}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "WebSocket 连接 / 断连 / 丢弃",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(ws_connection_count_total[$__rate_interval])) by (action, result)", "legendFormat": "{{action}} {{result}}", "refId": "A"},
        {"expr": "sum(rate(ws_delivery_count_total{result=\"dropped\"}[$__rate_interval]))", "legendFormat": "delivery dropped/s", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 0, "y": 20, "w": 8, "h": 8}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "WebSocket 广播延迟",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(ws_broadcast_duration_bucket[$__rate_interval])) by (le, mode, result))", "legendFormat": "{{mode}} {{result}} p95", "refId": "A"},
        {"expr": "histogram_quantile(0.99, sum(rate(ws_broadcast_duration_bucket[$__rate_interval])) by (le, mode, result))", "legendFormat": "{{mode}} {{result}} p99", "refId": "B"},
        {"expr": "histogram_quantile(0.95, sum(rate(ws_broadcast_recipients_bucket[$__rate_interval])) by (le, mode, result))", "legendFormat": "{{mode}} recipients p95", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 3, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 8, "y": 20, "w": 8, "h": 8}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "读接口 QPS",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(http_server_request_count_total{http_route=~\"/api/v1/items|/api/v1/items/[^/]+|/api/v1/items/\\\\{item_id\\\\}|/api/v1/items/[^/]+/ranking|/api/v1/items/\\\\{item_id\\\\}/ranking|/api/v1/rooms|/api/v1/rooms/[^/]+|/api/v1/rooms/\\\\{room_id\\\\}\"}[$__rate_interval])) by (http_route)", "legendFormat": "{{http_route}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 16, "y": 20, "w": 8, "h": 8}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "读接口 P95 / P99",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items|/api/v1/items/[^/]+|/api/v1/items/\\\\{item_id\\\\}|/api/v1/items/[^/]+/ranking|/api/v1/items/\\\\{item_id\\\\}/ranking|/api/v1/rooms|/api/v1/rooms/[^/]+|/api/v1/rooms/\\\\{room_id\\\\}\"}[$__rate_interval])) by (le, http_route))", "legendFormat": "{{http_route}} p95", "refId": "A"},
        {"expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_bucket{http_route=~\"/api/v1/items|/api/v1/items/[^/]+|/api/v1/items/\\\\{item_id\\\\}|/api/v1/items/[^/]+/ranking|/api/v1/items/\\\\{item_id\\\\}/ranking|/api/v1/rooms|/api/v1/rooms/[^/]+|/api/v1/rooms/\\\\{room_id\\\\}\"}[$__rate_interval])) by (le, http_route))", "legendFormat": "{{http_route}} p99", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8}
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Pod CPU / 内存",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"live-auction\", pod=~\"live-auction-backend.*\", container!=\"\", image!=\"\"}[$__rate_interval])) by (pod)", "legendFormat": "{{pod}} cpu cores", "refId": "A"},
        {"expr": "sum(container_memory_working_set_bytes{namespace=\"live-auction\", pod=~\"live-auction-backend.*\", container!=\"\", image!=\"\"}) by (pod)", "legendFormat": "{{pod}} memory", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8}
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Go runtime",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "process_runtime_go_goroutines", "legendFormat": "goroutines", "refId": "A"},
        {"expr": "process_runtime_go_memory_heap_alloc", "legendFormat": "heap alloc", "refId": "B"},
        {"expr": "rate(process_runtime_go_gc_count[$__rate_interval])", "legendFormat": "gc/s", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 0, "y": 36, "w": 8, "h": 8}
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "节点资源",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100", "legendFormat": "node cpu %", "refId": "A"},
        {"expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "node memory %", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 8, "y": 36, "w": 8, "h": 8}
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Pod 重启 / Ready",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"live-auction\", pod=~\"live-auction-backend.*\"}[$__range])) by (pod)", "legendFormat": "{{pod}} restarts", "refId": "A"},
        {"expr": "min(kube_pod_status_ready{namespace=\"live-auction\", pod=~\"live-auction-backend.*\", condition=\"true\"}) by (pod)", "legendFormat": "{{pod}} ready", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "gridPos": {"x": 16, "y": 36, "w": 8, "h": 8}
    },
    {
      "id": 19,
      "type": "logs",
      "title": "Warn / Error 日志",
      "datasource": {"type": "loki", "uid": "Loki"},
      "targets": [
        {"expr": "{service_name=\"live-auction-backend\"} | json | level =~ \"warn|error\"", "refId": "A"}
      ],
      "options": {"showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": false, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"},
      "gridPos": {"x": 0, "y": 44, "w": 24, "h": 8}
    }
  ]
}
